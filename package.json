{
  "name": "dj-visualizer",
  "version": "1.0.0",
  "description": "Audio-reactive fractal & abstract visualizer for external display (Mac)",
  "main": "main.js",
  "author": {
    "name": "Dj LuZa",
    "email": "info@djluza.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "com.djvisualizer.app",
    "productName": "DJ Visualizer",
    "copyright": "© Dj LuZa",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "svg/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
